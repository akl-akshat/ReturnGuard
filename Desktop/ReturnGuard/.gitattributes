# Normalize line endings: text files use LF in the repo, regardless of OS.
* text=auto eol=lf

# Shell scripts must be LF (they break with CRLF).
*.sh text eol=lf

# Windows batch files keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never normalize.
*.pdf binary
*.docx binary
*.png binary
*.jpg binary
*.ico binary
