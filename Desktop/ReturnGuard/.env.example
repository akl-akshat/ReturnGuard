# ReturnGuard configuration — copy to .env and fill in. NEVER commit a real .env.
# Every key maps 1:1 to a field on config.settings.Settings.

# ----- app -----
ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_JSON=true

# ----- database (Postgres + pgvector; holds domain data, vectors, checkpointer) -----
DATABASE_URL=postgresql://returnguard:returnguard@localhost:5432/returnguard
DB_POOL_MIN=1
DB_POOL_MAX=10
# Optional read-only DSN for the MCP servers; falls back to DATABASE_URL if blank.
READ_DATABASE_URL=

# ----- kafka -----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=returnguard-workers
TOPIC_REQUESTS=returns.requests.v1
TOPIC_RESOLUTIONS=returns.resolutions.v1
TOPIC_ESCALATIONS=returns.escalations.v1
TOPIC_AUDIT=returns.audit.v1
TOPIC_OUTCOMES=returns.outcomes.v1
TOPIC_DLQ=returns.deadletter.v1

# ----- LLM provider -----
# Use 'stub' for fully-offline deterministic runs (tests, eval, demos without a key).
# Use 'anthropic' for real Claude calls (then LLM_API_KEY is required).
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS=1024

# ----- embeddings -----
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=stub-hash-384
EMBEDDING_DIM=384

# ----- RAG -----
RAG_TOP_K=4

# ----- financial guardrails (SRS Appendix B; INR) -----
MAX_COUPON_PCT=0.20
MAX_COUPON_ABS=300
MAX_AUTO_REFUND_ABS=2000
RISK_ESCALATION_THRESHOLD=0.70
MAX_GOODWILL_CREDIT=150
AUTO_REFUND_RATE_LIMIT=3
AUTO_REFUND_RATE_WINDOW_DAYS=30

# ----- graph control -----
MAX_ITERATIONS=12

# ----- observability (optional; off by default) -----
TRACING_ENABLED=false
TRACING_PROVIDER=none
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
LANGSMITH_API_KEY=

# ----- service -----
API_HOST=0.0.0.0
API_PORT=8000
